// Travel Verification Tool - app.js
// Source of truth: data/trips.json and data/events.json
// DO NOT modify data files. Gap detection is script-side only.

let tripsData = [];
let eventsData = [];
let currentView = 'table';

const segIcon = t => ({Cruise:'\u{1F6A2}',Flight:'\u2708\uFE0F',Train:'\u{1F686}',Bus:'\u{1F68C}',Accommodation:'\u{1F3E8}'}[t]||'\u{1F4CD}');
const fmtDate = d => d ? new Date(d).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : '';
const fmtShort = d => d ? new Date(d).toLocaleDateString('en-US',{month:'short',day:'numeric'}) : '';
const daysBetween = (a,b) => Math.round((new Date(b)-new Date(a))/(86400000));

function getSegStart(seg) {
    if (seg.DeparturePort && seg.DeparturePort.Time) return seg.DeparturePort.Time;
    if (seg.Departure && seg.Departure.Time) return seg.Departure.Time;
    if (seg.CheckInDate) return seg.CheckInDate;
    return null;
}
function getSegEnd(seg) {
    if (seg.ArrivalPort && seg.ArrivalPort.Time) return seg.ArrivalPort.Time;
    if (seg.Arrival && seg.Arrival.Time) return seg.Arrival.Time;
    if (seg.CheckOutDate) return seg.CheckOutDate;
    return null;
}
function getSegFrom(seg) {
    if (seg.DeparturePort) return `${seg.DeparturePort.City||''}, ${seg.DeparturePort.CountryCode||''}`;
    if (seg.Departure) return seg.Departure.Code ? `${seg.Departure.City} (${seg.Departure.Code})` : (seg.Departure.City||'');
    if (seg.City) return `${seg.City}, ${seg.CountryCode||''}`;
    return '';
}
function getSegTo(seg) {
    if (seg.ArrivalPort) return `${seg.ArrivalPort.City||''}, ${seg.ArrivalPort.CountryCode||''}`;
    if (seg.Arrival) return seg.Arrival.Code ? `${seg.Arrival.City} (${seg.Arrival.Code})` : (seg.Arrival.City||'');
    if (seg.City) return `${seg.City}, ${seg.CountryCode||''}`;
    return '';
}
function getSegDetail(seg) {
    switch(seg.SegmentType) {
        case 'Cruise': return `${seg.CruiseLine||''} ${seg.Ship||''}${seg.Stateroom ? ' ('+seg.Stateroom+')' : ''}`.trim();
        case 'Flight': return `${seg.Airline||''}${seg.FlightNumber ? ' '+seg.FlightNumber : ''}${seg.SeatClass ? ' - '+seg.SeatClass : ''}`.trim();
        case 'Train': return `${seg.Operator||''}${seg.TrainNumber ? ' '+seg.TrainNumber : ''}${seg.SeatClass ? ' - '+seg.SeatClass : ''}`.trim();
        case 'Bus': return `${seg.Operator||''} ${seg.Route||''}`.trim();
        case 'Accommodation': return seg.DisplayName||seg.City||'';
        default: return seg.SegmentType||'';
    }
}
function getTripDateRange(trip) {
    let min = null, max = null;
    for (const seg of trip.Segments||[]) {
        const s = getSegStart(seg), e = getSegEnd(seg);
        if (s && (!min || new Date(s) < new Date(min))) min = s;
        if (e && (!max || new Date(e) > new Date(max))) max = e;
    }
    return { start: min, end: max };
}
function getTripYear(trip) {
    const { start } = getTripDateRange(trip);
    return start ? new Date(start).getFullYear() : 'Unknown';
}
function getEventsForTrip(tripId) {
    return eventsData.filter(e => e.TripId === tripId);
}

function groupSegments(segments) {
    const groups = [];
    const used = new Set();
    for (let i = 0; i < segments.length; i++) {
        if (used.has(i)) continue;
        const seg = segments[i];
        if (seg.SegmentType === 'Flight' && seg.BookingNumber) {
            const connected = [seg];
            used.add(i);
            for (let j = i + 1; j < segments.length; j++) {
                if (used.has(j)) continue;
                if (segments[j].SegmentType === 'Flight' && segments[j].BookingNumber === seg.BookingNumber) {
                    connected.push(segments[j]);
                    used.add(j);
                }
            }
            if (connected.length > 1) {
                connected.sort((a,b) => new Date(getSegStart(a)||0) - new Date(getSegStart(b)||0));
                groups.push({ type: 'flight-group', segments: connected, booking: seg.BookingNumber });
            } else {
                groups.push({ type: 'single', segment: seg });
            }
        } else if (seg.SegmentType === 'Train') {
            const trainGroup = [seg];
            used.add(i);
            let lastEnd = getSegEnd(seg);
            for (let j = i + 1; j < segments.length; j++) {
                if (used.has(j)) continue;
                if (segments[j].SegmentType !== 'Train') break;
                const nextStart = getSegStart(segments[j]);
                if (lastEnd && nextStart) {
                    const gapHours = (new Date(nextStart) - new Date(lastEnd)) / (1000*60*60);
                    if (gapHours >= 0 && gapHours <= 3) {
                        trainGroup.push(segments[j]);
                        used.add(j);
                        lastEnd = getSegEnd(segments[j]);
                    } else break;
                } else break;
            }
            if (trainGroup.length > 1) {
                groups.push({ type: 'train-group', segments: trainGroup });
            } else {
                groups.push({ type: 'single', segment: seg });
            }
        } else {
            used.add(i);
            groups.push({ type: 'single', segment: seg });
        }
    }
    return groups;
}

function detectGaps() {
    const gaps = [];
    for (const trip of tripsData) {
        const segs = trip.Segments || [];
        for (const seg of segs) {
            if (!seg.BookingNumber || seg.BookingNumber === '???') {
                gaps.push({ type: 'missing-booking', trip: trip.TripName, tripId: trip.TripId,
                    detail: `${segIcon(seg.SegmentType)} ${seg.SegmentType}: ${getSegFrom(seg)} to ${getSegTo(seg)}`, severity: 'warning' });
            }
        }
        for (const seg of segs) {
            if (seg.Source === 'inferred') {
                gaps.push({ type: 'inferred', trip: trip.TripName, tripId: trip.TripId,
                    detail: `${segIcon(seg.SegmentType)} ${seg.SegmentType}: ${getSegFrom(seg)} to ${getSegTo(seg)}`, severity: 'info' });
            }
        }
        const sorted = [...segs].filter(s => getSegStart(s) && getSegEnd(s))
            .sort((a,b) => new Date(getSegStart(a)) - new Date(getSegStart(b)));
        for (let i = 0; i < sorted.length - 1; i++) {
            const end = new Date(getSegEnd(sorted[i]));
            const nextStart = new Date(getSegStart(sorted[i+1]));
            const gapDays = (nextStart - end) / 86400000;
            if (gapDays > 2 && sorted[i].SegmentType !== 'Accommodation' && sorted[i+1].SegmentType !== 'Accommodation') {
                gaps.push({ type: 'time-gap', trip: trip.TripName, tripId: trip.TripId,
                    detail: `${Math.round(gapDays)} day gap: ${getSegTo(sorted[i])} (${fmtShort(getSegEnd(sorted[i]))}) to ${getSegFrom(sorted[i+1])} (${fmtShort(getSegStart(sorted[i+1]))})`,
                    severity: 'error' });
            }
        }
        for (const seg of segs) {
            const missing = [];
            if (seg.SegmentType === 'Flight') {
                if (!seg.Airline) missing.push('Airline');
                if (!seg.FlightNumber) missing.push('FlightNumber');
            }
            if (seg.SegmentType === 'Cruise') {
                if (!seg.CruiseLine) missing.push('CruiseLine');
                if (!seg.Ship) missing.push('Ship');
            }
            if (missing.length > 0) {
                gaps.push({ type: 'missing-field', trip: trip.TripName, tripId: trip.TripId,
                    detail: `${segIcon(seg.SegmentType)} ${seg.SegmentType}: missing ${missing.join(', ')}`, severity: 'warning' });
            }
        }
    }
    return gaps;
}

// ==================== STATS BAR ====================
function renderStats() {
    const el = document.getElementById('stats-bar');
    const totalTrips = tripsData.length;
    const totalSegs = tripsData.reduce((n,t) => n + (t.Segments||[]).length, 0);
    const totalEvents = eventsData.length;
    const cruises = tripsData.reduce((n,t) => n + (t.Segments||[]).filter(s=>s.SegmentType==='Cruise').length, 0);
    const flights = tripsData.reduce((n,t) => n + (t.Segments||[]).filter(s=>s.SegmentType==='Flight').length, 0);
    const gaps = detectGaps();
    const errors = gaps.filter(g => g.severity === 'error').length;
    const warnings = gaps.filter(g => g.severity === 'warning').length;
    const inferred = gaps.filter(g => g.type === 'inferred').length;
    el.innerHTML = `
        <span class="stat-pill"><span class="num">${totalTrips}</span>Trips</span>
        <span class="stat-pill"><span class="num">${totalSegs}</span>Segments</span>
        <span class="stat-pill"><span class="num">${cruises}</span>Cruises</span>
        <span class="stat-pill"><span class="num">${flights}</span>Flights</span>
        <span class="stat-pill"><span class="num">${totalEvents}</span>Events</span>
        ${errors ? `<span class="stat-pill danger"><span class="num">${errors}</span>Time Gaps</span>` : ''}
        ${warnings ? `<span class="stat-pill warning"><span class="num">${warnings}</span>Warnings</span>` : ''}
        ${inferred ? `<span class="stat-pill warning"><span class="num">${inferred}</span>Inferred</span>` : ''}
    `;
}

// ==================== TABLE VIEW ====================
function segRowHTML(seg) {
    const type = seg.SegmentType || '';
    const typeLow = type.toLowerCase();
    const booking = seg.BookingNumber;
    const source = seg.Source || '';
    const isInferred = source === 'inferred';
    const isMissing = !booking || booking === '???';
    const rowClass = isInferred ? 'seg-row inferred-row' : (isMissing ? 'seg-row gap-row' : 'seg-row');
    return `<div class="${rowClass}">
        <span><span class="badge badge-${typeLow}">${segIcon(type)} ${type}</span></span>
        <span class="booking-ref">${booking && booking !== '???' ? booking : '<span class="missing-field">No Ref</span>'}</span>
        <span>${getSegDetail(seg)}</span>
        <span>${getSegFrom(seg)}</span>
        <span>${getSegTo(seg)}</span>
        <span>${fmtShort(getSegStart(seg))}</span>
        <span class="badge badge-${source}">${source}</span>
    </div>`;
}

function legRowHTML(seg) {
    return `<div class="seg-row leg-row">
        <span><span class="badge badge-${(seg.SegmentType||'').toLowerCase()}">${segIcon(seg.SegmentType)}</span></span>
        <span class="booking-ref">${seg.FlightNumber || seg.TrainNumber || ''}</span>
        <span>${getSegDetail(seg)}</span>
        <span>${getSegFrom(seg)}</span>
        <span>${getSegTo(seg)}</span>
        <span>${fmtShort(getSegStart(seg))}</span>
        <span class="text-muted">${seg.Source||''}</span>
    </div>`;
}

function cruiseHTML(seg) {
    const ports = seg.PortsOfCall || [];
    if (ports.length === 0) return segRowHTML(seg);
    const booking = seg.BookingNumber;
    const source = seg.Source || '';
    return `<div class="cruise-expandable" onclick="this.classList.toggle('expanded'); event.stopPropagation();">
        <div class="cruise-header">
            <span class="expand-icon">\u25B6</span>
            <div class="seg-row-inner">
                <span><span class="badge badge-cruise">${segIcon('Cruise')} Cruise</span></span>
                <span class="booking-ref">${booking || ''}</span>
                <span>${getSegDetail(seg)}</span>
                <span>${getSegFrom(seg)}</span>
                <span>${getSegTo(seg)}</span>
                <span>${fmtShort(getSegStart(seg))}</span>
                <span class="badge badge-${source}">${source}</span>
            </div>
        </div>
        <div class="cruise-ports">
            <div class="port-list">
                ${ports.map(p => `<span class="port-chip"><span class="port-date">${p.Date ? fmtShort(p.Date+'T12:00:00') : ''}</span> ${p.City || p.PortName}${p.CountryCode ? ' ('+p.CountryCode+')' : ''}</span>`).join('')}
            </div>
        </div>
    </div>`;
}

function connectionGroupHTML(group) {
    const segs = group.segments;
    const first = segs[0]; const last = segs[segs.length - 1];
    const icon = group.type === 'flight-group' ? segIcon('Flight') : segIcon('Train');
    const typeName = group.type === 'flight-group' ? 'Flight' : 'Train';
    const typeLow = typeName.toLowerCase();
    const booking = group.booking || first.BookingNumber || '';
    const source = first.Source || '';
    return `<div class="connection-group" onclick="this.classList.toggle('expanded'); event.stopPropagation();">
        <div class="connection-header">
            <span class="expand-icon">\u25B6</span>
            <span><span class="badge badge-${typeLow}">${icon} ${typeName} (${segs.length} legs)</span></span>
            <span class="booking-ref">${booking}</span>
            <span>${segs.map(s => getSegDetail(s)).join(' / ')}</span>
            <span>${getSegFrom(first)}</span>
            <span>${getSegTo(last)}</span>
            <span>${fmtShort(getSegStart(first))}</span>
            <span class="badge badge-${source}">${source}</span>
        </div>
        <div class="connection-legs">
            ${segs.map(s => legRowHTML(s)).join('')}
        </div>
    </div>`;
}

function renderTableView(filtered) {
    const wrapper = document.getElementById('table-wrapper');
    if (filtered.length === 0) { wrapper.innerHTML = '<div class="empty-msg">No trips match filters</div>'; return; }
    // Sort descending by start date
    filtered.sort((a,b) => {
        const aS = getTripDateRange(a).start, bS = getTripDateRange(b).start;
        return new Date(bS||0) - new Date(aS||0);
    });
    let html = '';
    for (const trip of filtered) {
        const { start, end } = getTripDateRange(trip);
        const events = getEventsForTrip(trip.TripId);
        const segs = trip.Segments || [];
        const groups = groupSegments(segs);
        const hasMissing = segs.some(s => !s.BookingNumber || s.BookingNumber === '???');
        const hasInferred = segs.some(s => s.Source === 'inferred');
        const extraClass = hasMissing ? 'has-missing' : (hasInferred ? 'has-gaps' : '');

        // Build segment types badges
        const typeSet = new Set(segs.map(s => s.SegmentType));
        const typeBadges = [...typeSet].map(t => `<span class="badge badge-${t.toLowerCase()}">${segIcon(t)}</span>`).join('');

        html += `<div class="trip-group ${extraClass}" onclick="this.classList.toggle('expanded')">
            <div class="trip-header">
                <span class="expand-icon">\u25B6</span>
                <span class="trip-title">${trip.TripName}</span>
                <span class="trip-badges">${typeBadges}</span>
                <span class="trip-dates">${fmtDate(start)} - ${fmtDate(end)}</span>
            </div>
            <div class="trip-body" onclick="event.stopPropagation()">`;

        if (trip.HomeAtStart || trip.HomeAtEnd) {
            html += `<div class="home-info">`;
            if (trip.HomeAtStart) html += `<strong>Home at start:</strong> ${trip.HomeAtStart}`;
            if (trip.HomeAtStart && trip.HomeAtEnd) html += ' | ';
            if (trip.HomeAtEnd) html += `<strong>Home at end:</strong> ${trip.HomeAtEnd}`;
            html += `</div>`;
        }

        html += `<div class="seg-grid-header">
            <span>Type</span><span>Booking</span><span>Detail</span><span>From</span><span>To</span><span>Date</span><span>Source</span>
        </div>`;

        for (const g of groups) {
            if (g.type === 'single') {
                if (g.segment.SegmentType === 'Cruise') {
                    html += cruiseHTML(g.segment);
                } else {
                    html += segRowHTML(g.segment);
                }
            } else if (g.type === 'flight-group' || g.type === 'train-group') {
                html += connectionGroupHTML(g);
            }
        }

        if (events.length > 0) {
            html += `<div class="events-section"><div class="events-label">\u{1F389} Events (${events.length})</div>`;
            for (const ev of events) {
                html += `<span class="event-chip">${ev.EventType === 'Excursion' ? '\u{1F3AF}' : '\u{1F3C6}'} ${ev.Title} <span class="text-muted">${fmtShort(ev.StartTime)}</span></span>`;
            }
            html += `</div>`;
        }

        html += `</div></div>`;
    }
    wrapper.innerHTML = html;
}

// ============ TIMELINE VIEW ============

function renderTimelineView(filteredTrips) {
    const container = document.getElementById('timeline-container');
    if (!filteredTrips.length) {
        container.innerHTML = '<p class="empty-msg">No trips match your filters.</p>';
        return;
    }

    // Group by year, descending
    const byYear = {};
    for (const trip of filteredTrips) {
        const y = getTripYear(trip);
        if (!byYear[y]) byYear[y] = [];
        byYear[y].push(trip);
    }

    const years = Object.keys(byYear).sort((a,b) => b - a);

    let html = '';
    for (const year of years) {
        const trips = byYear[year];
        // Sort trips within year descending
        trips.sort((a,b) => {
            const aStart = getTripDateRange(a).start;
            const bStart = getTripDateRange(b).start;
            return new Date(bStart||0) - new Date(aStart||0);
        });

        html += `<div class="timeline-year">`;
        html += `<div class="year-label" onclick="this.parentElement.classList.toggle('collapsed')">${year} <span class="year-count">(${trips.length} trips)</span></div>`;

        for (const trip of trips) {
            const range = getTripDateRange(trip);
            const events = getTripEvents(trip.TripId);
            const grouped = groupSegments(trip.Segments || []);
            const hasGaps = (trip.Segments||[]).some(s => !s.BookingNumber || s.Source === 'inferred');

            html += `<div class="timeline-trip${hasGaps ? ' has-gaps' : ''}">`;
            html += `<div class="timeline-header" onclick="this.parentElement.classList.toggle('expanded')">`;
            html += `<span class="arrow">&#9654;</span>`;
            html += `<span class="trip-name">${esc(trip.TripName)}</span>`;
            html += `<span class="trip-dates">${fmtDate(range.start)} - ${fmtDate(range.end)}</span>`;
            html += `</div>`;

            html += `<div class="timeline-body">`;

            // Home info
            if (trip.HomeAtStart || trip.HomeAtEnd) {
                html += `<div class="home-info">`;
                if (trip.HomeAtStart) html += `Home: <strong>${esc(trip.HomeAtStart)}</strong>`;
                if (trip.HomeAtStart && trip.HomeAtEnd && trip.HomeAtStart !== trip.HomeAtEnd) {
                    html += ` &rarr; <strong>${esc(trip.HomeAtEnd)}</strong>`;
                }
                html += `</div>`;
            }

            for (const group of grouped) {
                if (group.type === 'single') {
                    html += renderTimelineSegment(group.segment);
                } else if (group.type === 'flight-group') {
                    html += renderTimelineConnection(group.segments, 'Flight');
                } else if (group.type === 'train-group') {
                    html += renderTimelineConnection(group.segments, 'Train');
                }
            }

            // Events
            if (events.length > 0) {
                html += `<div class="events-section">`;
                html += `<div class="events-label">Events & Excursions</div>`;
                for (const ev of events) {
                    html += `<div class="event-chip">${esc(ev.Title)} <span class="text-muted">${fmtShort(ev.StartTime)}</span></div>`;
                }
                html += `</div>`;
            }

            html += `</div></div>`;
        }
        html += `</div>`;
    }
    container.innerHTML = html;
}

function renderTimelineSegment(seg) {
    const start = getSegStart(seg);
    const end = getSegEnd(seg);
    const hasPorts = seg.SegmentType === 'Cruise' && seg.PortsOfCall && seg.PortsOfCall.length > 0;
    const booking = getBookingRef(seg);
    const bgColor = `var(--${(seg.SegmentType||'').toLowerCase()})`;

    let cls = 'tl-segment';
    if (hasPorts) cls += ' has-ports';

    let html = `<div class="${cls}"${hasPorts ? ' onclick="this.classList.toggle(\'expanded\')"' : ''}>`;
    html += `<div class="seg-icon" style="background:${bgColor}22;color:${bgColor}">${segIcon(seg.SegmentType)}</div>`;
    html += `<div class="seg-content">`;
    html += `<div class="seg-title">${esc(getSegDetail(seg))}${hasPorts ? ' <span class="text-muted">(' + seg.PortsOfCall.length + ' ports, click to expand)</span>' : ''}</div>`;
    html += `<div class="seg-meta">${esc(getSegFrom(seg))} &rarr; ${esc(getSegTo(seg))}</div>`;
    html += `<div class="seg-meta">${fmtDate(start)} - ${fmtDate(end)}${booking ? ' &bull; Booking: ' + esc(booking) : ''}${seg.Source === 'inferred' ? ' &bull; <span class="badge badge-inferred">inferred</span>' : ''}</div>`;

    if (hasPorts) {
        html += `<div class="tl-ports">`;
        for (const port of seg.PortsOfCall) {
            html += `<span class="port-chip"><span class="port-date">${fmtShort(port.Date)}</span> ${esc(port.City || port.PortName)}</span>`;
        }
        html += `</div>`;
    }

    html += `</div></div>`;
    return html;
}

function renderTimelineConnection(segments, type) {
    const first = segments[0];
    const last = segments[segments.length - 1];
    const overallFrom = getSegFrom(first);
    const overallTo = getSegTo(last);
    const overallStart = getSegStart(first);
    const overallEnd = getSegEnd(last);
    const bgColor = `var(--${type.toLowerCase()})`;

    let html = `<div class="tl-segment connection-tl" onclick="this.classList.toggle('expanded')">`;
    html += `<div class="seg-icon" style="background:${bgColor}22;color:${bgColor}">${segIcon(type)}</div>`;
    html += `<div class="seg-content">`;
    html += `<div class="seg-title">${esc(getSegDetail(first))} <span class="text-muted">(${segments.length} legs, click to expand)</span></div>`;
    html += `<div class="seg-meta">${esc(overallFrom)} &rarr; ${esc(overallTo)}</div>`;
    html += `<div class="seg-meta">${fmtDate(overallStart)} - ${fmtDate(overallEnd)}</div>`;

    html += `<div class="connection-detail">`;
    for (const leg of segments) {
        html += `<div class="conn-leg">${segIcon(type)} ${esc(getSegDetail(leg))}: ${esc(getSegFrom(leg))} &rarr; ${esc(getSegTo(leg))} (${fmtTime(getSegStart(leg))} - ${fmtTime(getSegEnd(leg))})</div>`;
    }
    html += `</div>`;

    html += `</div></div>`;
    return html;
}
